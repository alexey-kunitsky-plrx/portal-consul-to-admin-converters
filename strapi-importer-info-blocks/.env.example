# Copy to .env and fill in with values for the target environment.
# Pick ONE of the URLs below (stage / localhost / prod) and put the matching API token.

# Stage
STRAPI_URL=https://itwa-stage-personal-account-admin.local.playrix.com

# Localhost
# STRAPI_URL=http://localhost:1337

# Production
# STRAPI_URL=https://itwa-personal-account-admin.playrix.com

STRAPI_TOKEN=your_api_token_here
